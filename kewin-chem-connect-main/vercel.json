{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://kewinchem-backend.onrender.com/api/:path*"
    },
    {
      "source": "/:path((?!api).*)*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
